# ===========================================================================
# Site Gustavo Trotta — Variáveis de ambiente
#
# Copie este arquivo para `.env.local` e preencha com os valores reais.
# `.env.local` está no .gitignore — nunca será commitado.
# ===========================================================================

# ─── Supabase ──────────────────────────────────────────────────────────────
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Settings → API → Project API keys → "anon" "public"
# Esta chave é pública — pode ir para o cliente.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Settings → API → Project API keys → "service_role"
# Esta chave é SECRETA — só usar em código server-side.
# Permite operações de admin (criar usuários, etc).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Resend (email transacional) ───────────────────────────────────────────
# https://resend.com → Sign Up → API Keys → Create
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email que recebe notificações de novos leads
LEAD_NOTIFY_EMAIL=gustavo.mendonca@valorinvestimentos.com.br

# Email remetente. Use "onboarding@resend.dev" até configurar DNS de domínio próprio.
LEAD_NOTIFY_FROM=Gustavo Trotta · Site <onboarding@resend.dev>

# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
